rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /exams/{examId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      
      match /questions/{questionId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
      }
    }

    match /users/{userId}/vocabulary/{wordId} {
      function isValidVocab(data) {
        return data.word is string && data.word.size() > 0 && data.word.size() < 100
            && data.definition is string && data.definition.size() > 0
            && data.userId == request.auth.uid;
      }
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidVocab(incoming());
      allow update: if isOwner(userId) && isValidVocab(incoming());
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/attempts/{attemptId} {
      function isValidAttempt(data) {
        return data.score is number && data.totalQuestions is number 
            && data.userId == request.auth.uid;
      }
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidAttempt(incoming());
      allow update: if isOwner(userId) && isValidAttempt(incoming());
      allow delete: if isOwner(userId);
    }
  }
}
